#!/usr/bin/env bash
set -euo pipefail

choice=$(printf "蟀惀 Shutdown\n蟀湁 Reboot\n蟀挷 Suspend\n髰瘝 Logout\n蟀尵 Lock" | wofi --dmenu --prompt "Power" 2>/dev/null)

case "$choice" in
    *Shutdown) loginctl poweroff ;;
    *Reboot)   loginctl reboot ;;
    *Suspend)  loginctl suspend ;;
    *Logout)   hyprctl dispatch exit ;;
    *Lock)     "$HOME/.config/hypr/start-hyprlock" ;;
esac
